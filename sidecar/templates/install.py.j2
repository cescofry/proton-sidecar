from sidecar.hook import Hook as BaseHook
from sidecar.context import InstallContext, LaunchContext


class Hook(BaseHook):
    def post_install(self, ctx: InstallContext) -> None:
        """Called after extraction. Use for DLL deployment, config file generation, etc."""
        pass

    def pre_launch(self, ctx: LaunchContext) -> None:
        """Called before Proton starts. Use for environment setup, port checks, etc."""
        pass

    def post_launch(self, ctx: LaunchContext) -> None:
        """Called after Proton exits. Use for cleanup, log archiving, etc."""
        pass

    def uninstall(self, ctx: InstallContext) -> None:
        """Called by `sidecar remove`. Reverse anything done in post_install."""
        pass
